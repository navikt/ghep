{
    "display_information": {
        "name": "Ghep",
        "description": "Posts Github events to your chosen channel",
        "background_color": "#000000"
    },
    "features": {
        "bot_user": {
            "display_name": "Ghep",
            "always_online": false
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "channels:join",
                "channels:read",
                "chat:write",
                "chat:write.public",
                "reactions:read",
                "reactions:write",
                "users:read.email",
                "users:read"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "org_deploy_enabled": false,
        "socket_mode_enabled": false,
        "token_rotation_enabled": false,
        "is_mcp_enabled": false
    }
}
