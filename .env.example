# GitHub App credentials — create a GitHub App at https://github.com/settings/apps
GITHUB_ORG=navikt

# Path to the teams config YAML
REPOS_CONFIG_FILE_PATH=./teams-local.yaml

# Set to true to subscribe to all org repos instead of per-team
GHEP_SUBSCRIBE_TO_ORG=false

# Comma-separated list of repos to ignore (optional)
# GITHUB_BLOCKLIST_REPOS=

# Slack channel for pull requests from non-team members (optional)
# EXTERNAL_CONTRIBUTORS_CHANNEL=

# HTTP server address (optional)
# SERVER_ADDR=0.0.0.0:8080

# Base path for the webhook endpoint (optional)
# API_BASE_PATH=

# PostgreSQL connection string
PGURL=postgres://postgres:postgres@localhost:5432/ghep
